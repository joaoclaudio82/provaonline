# Copie para .env e ajuste os valores antes de subir.

# Conexão com o PostgreSQL (no docker-compose o host é "db").
DATABASE_URL=postgresql+psycopg://prova:prova@db:5432/prova

# Senha única da área do professor. TROQUE antes de usar de verdade.
PROFESSOR_PASSWORD=troque-esta-senha

# Origens permitidas para o front. Em produção, liste o domínio real.
CORS_ORIGINS=*

# Parâmetros e limites da prova (opcionais; têm padrão no código).
DEFAULT_QUESTION_COUNT=20
MIN_QUESTION_COUNT=5
MAX_QUESTION_COUNT=50
DEFAULT_TIME_MINUTES=120
MIN_TIME_MINUTES=5
MAX_TIME_MINUTES=300
MAX_STUDENTS=50
